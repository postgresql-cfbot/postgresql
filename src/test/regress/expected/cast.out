-- test deparse
SET datestyle TO ISO, YMD;
CREATE VIEW safecastview AS
SELECT
      CAST('2022-01-01' COLLATE "C" COLLATE "POSIX" as DATE DEFAULT NULL ON CONVERSION ERROR) as cast,
      CAST('1234' as char(3) DEFAULT -1111 ON CONVERSION ERROR) as cast0,
       CAST(1 as date DEFAULT (('2025-Dec-06'::date + random(min=>1, max=>1::int))) ON CONVERSION ERROR) as cast1,
       CAST(ARRAY[['1'], ['three'],['a']] AS int[] DEFAULT '{1,2}' ON CONVERSION ERROR) as cast2,
       CAST(ARRAY[['1', '2'], ['three', 'a']] AS date[] DEFAULT NULL ON CONVERSION ERROR) as cast3,
       CAST(ARRAY['three'] AS INT[] DEFAULT '{1,2}' ON CONVERSION ERROR) as cast4,
       CAST(CAST(1 AS int DEFAULT 0 ON CONVERSION ERROR) + 70000::int2::int4 AS int DEFAULT -1 ON CONVERSION ERROR) as cast5;
\sv safecastview
CREATE OR REPLACE VIEW public.safecastview AS
 SELECT CAST('2022-01-01'::text COLLATE "POSIX" AS date DEFAULT NULL::date ON CONVERSION ERROR) AS "cast",
    CAST('1234'::text AS character(3) DEFAULT '-1111'::integer::character(3) ON CONVERSION ERROR) AS cast0,
    CAST(1 AS date DEFAULT '2025-12-06'::date + random(min => 1, max => 1) ON CONVERSION ERROR) AS cast1,
    CAST(ARRAY[ARRAY[1], ARRAY['three'], ARRAY['a']] AS integer[] DEFAULT '{1,2}'::integer[] ON CONVERSION ERROR) AS cast2,
    CAST(ARRAY[ARRAY['1', '2'], ARRAY['three', 'a']] AS date[] DEFAULT NULL::date[] ON CONVERSION ERROR) AS cast3,
    CAST(ARRAY['three'] AS integer[] DEFAULT '{1,2}'::integer[] ON CONVERSION ERROR) AS cast4,
    CAST((CAST(1 AS integer DEFAULT 0 ON CONVERSION ERROR)) + 70000::smallint::integer AS integer DEFAULT '-1'::integer ON CONVERSION ERROR) AS cast5
SELECT * FROM safecastview;
    cast    | cast0 |   cast1    | cast2 | cast3 | cast4 | cast5 
------------+-------+------------+-------+-------+-------+-------
 2022-01-01 | 123   | 2025-12-07 | {1,2} |       | {1,2} |    -1
(1 row)

CREATE VIEW safecastview1 AS
SELECT CAST(ARRAY[['1'], ['three'],['a']] AS d_int_arr
            DEFAULT '{41,43}' ON CONVERSION ERROR) as cast1,
       CAST(ARRAY[['1', '2', 1.1], ['three', true, B'01']] AS d_int_arr
            DEFAULT '{41,43}' ON CONVERSION ERROR) as cast2;
\sv safecastview1
CREATE OR REPLACE VIEW public.safecastview1 AS
 SELECT CAST(ARRAY[ARRAY[1], ARRAY['three'], ARRAY['a']] AS d_int_arr DEFAULT '{41,43}'::integer[]::d_int_arr ON CONVERSION ERROR) AS cast1,
    CAST(ARRAY[ARRAY[1, 2, 1.1::integer], ARRAY['three', true, '01'::"bit"]] AS d_int_arr DEFAULT '{41,43}'::integer[]::d_int_arr ON CONVERSION ERROR) AS cast2
SELECT * FROM safecastview1;
  cast1  |  cast2  
---------+---------
 {41,43} | {41,43}
(1 row)

