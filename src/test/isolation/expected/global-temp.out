    FROM pg_class c
    JOIN pg_tablespace s1 ON s1.oid = c.reltablespace
    LEFT JOIN pg_temp_class t ON t.oid = c.oid
    LEFT JOIN pg_tablespace s2 ON s2.oid = t.reltablespace
