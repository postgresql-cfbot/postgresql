DROP TABLE IF EXISTS t_1000_1000;
NOTICE:  table "t_1000_1000" does not exist, skipping
CREATE TABLE t_1000_1000 AS
SELECT
gs as id,
gs % 20 as id2,
(
    REPEAT('9', (gs % 200)) || '.' || REPEAT('9', 800)
)::NUMERIC(1000, 800) AS a,
(
    REPEAT('0', (gs % 200)) || '.' || REPEAT('0', 800)
)::NUMERIC(1000, 800) AS b
FROM GENERATE_SERIES(1, 1000) AS gs;
CREATE INDEX idx_t_1000_1000 ON t_1000_1000 USING btree(a);
VACUUM FREEZE ANALYZE t_1000_1000;
