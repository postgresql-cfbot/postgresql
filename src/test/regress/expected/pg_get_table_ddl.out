 ALTER TABLE pgtbl_ddl_test.cst ALTER COLUMN a SET STATISTICS 500;
 ALTER TABLE pgtbl_ddl_test.cst ALTER COLUMN b SET STATISTICS 0;
(3 rows)

-- Issue 3b: extended statistics SET STATISTICS.
