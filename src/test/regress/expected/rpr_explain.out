    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ((A | B) (A | B) (A | B) (A | B) (A | B) (A | B) (A | B) (A | B))
    DEFINE A AS v % 2 = 1, B AS v % 2 = 0
)');
