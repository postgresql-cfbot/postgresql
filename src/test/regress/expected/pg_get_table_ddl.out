CREATE STATISTICS ext_stat_s (dependencies) ON a, b FROM ext_stat_tbl;
ALTER STATISTICS ext_stat_s SET STATISTICS 750;
SELECT stmt FROM pg_get_table_ddl('ext_stat_tbl', owner => false) stmt;
