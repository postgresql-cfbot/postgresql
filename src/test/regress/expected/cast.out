                                        ^
-- DEFAULT expression cannot be set-returning
CREATE FUNCTION ret_setint() RETURNS SETOF integer AS
$$
BEGIN RETURN QUERY EXECUTE 'select 1 union all select 1'; END;
$$
LANGUAGE plpgsql IMMUTABLE;
