SELECT id, val, COUNT(*) OVER w as cnt
FROM rpr_plan
WINDOW w AS (
    ORDER BY id
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN (A+ B)
    DEFINE A AS val <= 50, B AS val > 50
)
ORDER BY id;
