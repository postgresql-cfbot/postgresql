-----------------------------------------------------------------------
 CREATE TABLE pc PARTITION OF p FOR VALUES FROM (0) TO (100);
 ALTER TABLE pc ADD CONSTRAINT chk CHECK (("pgtbl_ddl_q1.weird" > 0));
(2 rows)

DROP SCHEMA pgtbl_ddl_q1 CASCADE;
NOTICE:  drop cascades to table pgtbl_ddl_q1.p
