SELECT id, val, count(*) OVER w FROM rpr_nav WINDOW w AS (
    ORDER BY id
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    PATTERN (A+)
    DEFINE A AS LAST(val, -1) IS NULL
