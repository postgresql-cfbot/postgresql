-- Fixed length matches - all same length
CREATE VIEW rpr_ev_mlen_fixed AS
SELECT count(*) OVER w
FROM rpr_nfa_test
WINDOW w AS (
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN (A B C D E)
    DEFINE
        A AS cat = 'A', B AS cat = 'B', C AS cat = 'C',
        D AS cat = 'D', E AS cat = 'E'
);
