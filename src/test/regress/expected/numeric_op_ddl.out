INSERT INTO t_1000_200 SELECT id, id2, a, b FROM t
    UNION ALL SELECT id, id2, -a, -b FROM t
    UNION ALL SELECT g AS id, g % 20 AS id2, 0 AS a, 0 AS b from generate_series(1, 100) AS g;
