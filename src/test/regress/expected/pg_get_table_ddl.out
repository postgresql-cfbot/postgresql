-- NOT VALID CHECK must be emitted as ALTER TABLE ... ADD CONSTRAINT ... NOT VALID,
-- not inline in CREATE TABLE.  An inline constraint is always validated against
-- the empty table, which would silently flip convalidated to true on replay.
