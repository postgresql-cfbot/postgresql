 CREATE TABLE pgtbl_ddl_test.ps_child PARTITION OF pgtbl_ddl_test.ps_parent FOR VALUES FROM (0) TO (10);
 ALTER TABLE ONLY pgtbl_ddl_test.ps_child ALTER COLUMN b SET STORAGE EXTERNAL;
(3 rows)

-- Issue 6: a foreign-table partition must produce a WARNING and be skipped
-- rather than causing an error.
CREATE FOREIGN DATA WRAPPER dummy_fdw;
CREATE SERVER dummy_srv FOREIGN DATA WRAPPER dummy_fdw;
CREATE TABLE fpar (a int) PARTITION BY RANGE (a);
CREATE TABLE fpar_1 PARTITION OF fpar FOR VALUES FROM (0) TO (10);
CREATE FOREIGN TABLE fpar_2 PARTITION OF fpar
    FOR VALUES FROM (10) TO (20) SERVER dummy_srv;
SELECT stmt FROM pg_get_table_ddl('fpar', owner => false) stmt;
WARNING:  skipping foreign-table partition "fpar_2"
DETAIL:  pg_get_table_ddl() cannot reconstruct foreign table partitions.
                                               stmt                                               
--------------------------------------------------------------------------------------------------
 CREATE TABLE pgtbl_ddl_test.fpar (a integer) PARTITION BY RANGE (a);
 CREATE TABLE pgtbl_ddl_test.fpar_1 PARTITION OF pgtbl_ddl_test.fpar FOR VALUES FROM (0) TO (10);
(2 rows)

-- Issue 8: a partition child index with a custom name must be emitted as
-- CREATE INDEX + ATTACH PARTITION; CLUSTER ON that custom index must also work.
CREATE TABLE cc (a int) PARTITION BY RANGE (a);
CREATE TABLE cc_1 PARTITION OF cc FOR VALUES FROM (0) TO (10);
CREATE INDEX ON ONLY cc (a);
CREATE INDEX cc_custom ON cc_1 (a);
ALTER INDEX cc_a_idx ATTACH PARTITION cc_custom;
ALTER TABLE cc_1 CLUSTER ON cc_custom;
SELECT stmt FROM pg_get_table_ddl('cc', owner => false) stmt;
                                             stmt                                             
----------------------------------------------------------------------------------------------
 CREATE TABLE pgtbl_ddl_test.cc (a integer) PARTITION BY RANGE (a);
 CREATE TABLE pgtbl_ddl_test.cc_1 PARTITION OF pgtbl_ddl_test.cc FOR VALUES FROM (0) TO (10);
 CREATE INDEX cc_custom ON pgtbl_ddl_test.cc_1 USING btree (a);
 ALTER TABLE pgtbl_ddl_test.cc_1 CLUSTER ON cc_custom;
 CREATE INDEX cc_a_idx ON ONLY pgtbl_ddl_test.cc USING btree (a);
 ALTER INDEX pgtbl_ddl_test.cc_a_idx ATTACH PARTITION cc_custom;
(6 rows)

-- Issue 10: tablespace => false must suppress TABLESPACE from both CREATE INDEX
