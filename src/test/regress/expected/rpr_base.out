   AFTER MATCH SKIP PAST LAST ROW                                            +
   INITIAL                                                                   +
   PATTERN (a b+)                                                            +
   DEFINE                                                                    +
   a AS true,                                                                +
   b AS (PREV(FIRST(val, (1)::bigint), (2)::bigint) > 0) );
(1 row)

