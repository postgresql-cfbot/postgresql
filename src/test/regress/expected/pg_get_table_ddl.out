-- Kind-filter tests on partitioned tables with indexes.
--
-- only_kinds=index on a partitioned table: only the parent's CREATE INDEX (ON ONLY)
-- is emitted; no CREATE TABLE, no partition children (KIND_PARTITION absent).
SELECT * FROM pg_get_table_ddl('parted_mixed'::regclass, owner => false,
                               only_kinds => ARRAY['index']);
