-------------------------------------------------------------------------------
 CREATE TABLE "T" (id integer, val integer, CONSTRAINT chk CHECK ((val > 0)));
 CREATE INDEX "T_val_idx" ON "T" USING btree (val);
(2 rows)

DROP SCHEMA "PgTbl-Ddl-Q" CASCADE;
