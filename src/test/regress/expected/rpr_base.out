-- Deeply Nested Subqueries with RPR
SELECT * FROM (
    SELECT * FROM (
        SELECT * FROM (
            SELECT id, val,
                   COUNT(*) OVER w as cnt
            FROM rpr_stress
            WINDOW w AS (
                ORDER BY id
                ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
                PATTERN (A+)
                DEFINE A AS val > 0
            )
        ) sub1
    ) sub2
) sub3
WHERE cnt > 10
ORDER BY id;
 id | val | cnt 
----+-----+-----
  1 |  10 |  20
(1 row)

-- Complex Expression in DEFINE Clause
SELECT id, val,
       COUNT(*) OVER w as cnt
FROM rpr_stress
WINDOW w AS (
    ORDER BY id
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    PATTERN (A+ B)
    DEFINE A AS (val % 3 = 0 OR val % 5 = 0),
           B AS (val * 2 > 100 AND val / 2 < 100)
)
ORDER BY id;
 id | val | cnt 
