  1 |  10 |   0
  2 |  20 |   0
  3 |  30 |   0
  4 |  10 |   0
  5 |  50 |   0
  6 |  10 |   0
(6 rows)

-- Error: NULL offset
SELECT id, val, count(*) OVER w FROM rpr_nav WINDOW w AS (
    ORDER BY id
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    PATTERN (A+)
    DEFINE A AS FIRST(val, NULL::int8) IS NULL
);
