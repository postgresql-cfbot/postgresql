     val,                                                                    +
     count(*) OVER w AS cnt                                                  +
    FROM rpr_serial                                                          +
   WINDOW w AS (ORDER BY id ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING +
   AFTER MATCH SKIP PAST LAST ROW                                            +
   INITIAL                                                                   +
   PATTERN (((a+ b) | c) d | a b c)                                          +
   DEFINE                                                                    +
   a AS (val <= 15),                                                         +
   b AS (val <= 25),                                                         +
