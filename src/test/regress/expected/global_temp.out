       replace(d.stxdndistinct, '}, ', E'},\n') AS stxdndistinct,
       replace(d.stxddependencies, '}, ', E'},\n') AS stxddependencies
  FROM pg_statistic_ext s
  LEFT JOIN pg_temp_statistic_ext_data d ON d.stxoid = s.oid
 WHERE s.stxname = 'tmp2_stats';
