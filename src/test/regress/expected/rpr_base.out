       COUNT(*) OVER w as cnt
FROM rpr_planner
WINDOW w AS (
    PARTITION BY category
    ORDER BY id
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    PATTERN (A+)
    DEFINE A AS val > 0
)
ORDER BY category, id;
 id | category | val | cnt 
