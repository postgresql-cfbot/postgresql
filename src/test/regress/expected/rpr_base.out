  8 |  40 |   0
  9 |  45 |   0
 10 |  50 |   0
(10 rows)

-- Alternation + sequence + grouping
SELECT id, val, COUNT(*) OVER w as cnt
FROM rpr_pattern
WINDOW w AS (
    ORDER BY id
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    PATTERN (START (UP{2,} DOWN? | FLAT+) FINISH)
    DEFINE
        START AS val >= 0,
        UP AS val > 20,
        DOWN AS val <= 30,
        FLAT AS val BETWEEN 25 AND 35,
        FINISH AS val > 40
)
ORDER BY id;
