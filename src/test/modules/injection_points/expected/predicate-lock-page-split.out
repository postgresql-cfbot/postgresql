step s2_insert_wait_at_page_split: 
    DO $$
    DECLARE
        next_id int := 0;
        base_size bigint := pg_relation_size('test_table_id_idx');
    BEGIN
        LOOP
            INSERT INTO test_table VALUES (next_id);
            EXIT WHEN pg_relation_size('test_table_id_idx') > base_size;
            next_id := next_id - 1;
        END LOOP;
    END;
    $$;
