-- Issue 2: CONSTRAINT WITH (fillfactor) and USING INDEX TABLESPACE must be
-- preserved in the ADD CONSTRAINT body.
CREATE TABLE pko (a int, b int);
ALTER TABLE pko ADD CONSTRAINT pko_pk PRIMARY KEY (a) WITH (fillfactor=50);
ALTER TABLE pko ADD CONSTRAINT pko_u UNIQUE (b) WITH (fillfactor=60);
SELECT stmt FROM pg_get_table_ddl('pko', owner => false) stmt;
                                             stmt                                             
----------------------------------------------------------------------------------------------
 CREATE TABLE pgtbl_ddl_test.pko (a integer NOT NULL, b integer);
 ALTER TABLE pgtbl_ddl_test.pko ADD CONSTRAINT pko_pk PRIMARY KEY (a) WITH (fillfactor='50');
 ALTER TABLE pgtbl_ddl_test.pko ADD CONSTRAINT pko_u UNIQUE (b) WITH (fillfactor='60');
(3 rows)

-- Issue 2b: USING INDEX TABLESPACE in ADD CONSTRAINT.
