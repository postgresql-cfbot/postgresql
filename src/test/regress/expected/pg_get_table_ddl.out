-- Issue 12: ALTER INDEX ... ALTER COLUMN SET STATISTICS on a constraint-backed
-- index (PK, UNIQUE, EXCLUSION) must be emitted after the ADD CONSTRAINT.
-- EXCLUSION with an expression column is used because only expression columns
-- of an index support SET STATISTICS.
CREATE TABLE exs (a int, b int);
ALTER TABLE exs ADD CONSTRAINT exs_excl EXCLUDE USING btree ((a + 0) WITH =);
ALTER INDEX exs_excl ALTER COLUMN 1 SET STATISTICS 900;
SELECT stmt FROM pg_get_table_ddl('exs', owner => false) stmt;
                                              stmt                                              
------------------------------------------------------------------------------------------------
 CREATE TABLE pgtbl_ddl_test.exs (a integer, b integer);
 ALTER TABLE pgtbl_ddl_test.exs ADD CONSTRAINT exs_excl EXCLUDE USING btree (((a + 0)) WITH =);
 ALTER INDEX pgtbl_ddl_test.exs_excl ALTER COLUMN 1 SET STATISTICS 900;
(3 rows)

