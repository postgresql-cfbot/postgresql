CREATE TABLE t_9_2 (id int, id2 int, a NUMERIC(9, 2), b NUMERIC(11, 4));
CREATE TABLE t_18_2 (id int, id2 int, a NUMERIC(18, 2), b NUMERIC(20, 4));
CREATE TABLE t_38_2 (id int, id2 int, a NUMERIC(38, 2), b NUMERIC(40, 4));
CREATE TABLE t_80_16 (id int, id2 int, a NUMERIC(80, 16), b NUMERIC(90, 18));
CREATE TABLE t_175_35 (id int, id2 int, a NUMERIC(175, 35), b NUMERIC(190, 40));
CREATE TABLE t_400_80 (id int, id2 int, a NUMERIC(400, 80), b NUMERIC(420, 100));
CREATE TABLE t_1000_200 (id int, id2 int, a NUMERIC(1000, 200), b NUMERIC(1000, 220));
CREATE TABLE t_1000_800 (id int, id2 int, a NUMERIC(1000, 800), b NUMERIC(1000, 900));
CREATE TABLE t_1000_995 (id int, id2 int, a NUMERIC(1000, 995), b NUMERIC(1000, 1000));
CREATE TABLE t_base (id int, id2 int, astr text, bstr text);
INSERT INTO t_base
    SELECT  g,
            g % 20,
            string_agg(
                lpad(
                    (((g * 37 + k)::bigint * 1103515245 + 12345) % 1000000007)::text,
                    9, '0'
                    ),
                ''
                ORDER BY k
            ) AS astr,
            string_agg(
                lpad(
                    (((g * 131 + k)::bigint * 1284584123 + 89247) % 998244353)::text,
                    9, '0'
                    ),
                ''
                ORDER BY k
            ) AS bstr
    FROM generate_series(1, 2000) g,
        generate_series(1, 120) k
    GROUP BY g;
WITH t AS (
    SELECT id, id2,
        (substr(astr, 1, 7) || '.' || substr(astr, 8, 2))::numeric(9, 2) AS a,
        (substr(bstr, 1, 7) || '.' || substr(bstr, 8, 4))::numeric(11, 4) AS b
    FROM t_base
)
INSERT INTO t_9_2 SELECT id, id2, a, b FROM t
    UNION ALL SELECT id, id2, -a, -b FROM t
    UNION ALL SELECT g AS id, g % 20 AS id2, 0 AS a, 0 AS b from generate_series(1, 100) AS g;
WITH t AS (
    SELECT id, id2,
        (substr(astr, 1, 16) || '.' || substr(astr, 17, 2))::numeric(18, 2) AS a,
        (substr(bstr, 1, 16) || '.' || substr(bstr, 17, 4))::numeric(20, 4) AS b
    FROM t_base
)
INSERT INTO t_18_2 SELECT id, id2, a, b FROM t
    UNION ALL SELECT id, id2, -a, -b FROM t
    UNION ALL SELECT g AS id, g % 20 AS id2, 0 AS a, 0 AS b from generate_series(1, 100) AS g;
