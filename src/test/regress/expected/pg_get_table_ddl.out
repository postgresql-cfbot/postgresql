(1 row)

-- Issue 5: STORAGE and COMPRESSION overrides on inherited partition columns
-- must be emitted as post-CREATE ALTER TABLE statements.
CREATE TABLE ps_parent (a int, b text) PARTITION BY RANGE (a);
CREATE TABLE ps_child PARTITION OF ps_parent FOR VALUES FROM (0) TO (10);
ALTER TABLE ps_child ALTER COLUMN b SET STORAGE EXTERNAL;
SELECT stmt FROM pg_get_table_ddl('ps_parent', owner => false) stmt;
                                                  stmt                                                   
---------------------------------------------------------------------------------------------------------
