SELECT id, val, COUNT(*) OVER w FROM rpr_errors
WINDOW w AS (
    ORDER BY id
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    PATTERN (A)
    DEFINE
      B AS TRUE
);
