ALTER TABLE rls_pol ENABLE ROW LEVEL SECURITY;
CREATE POLICY rls_pol_p ON rls_pol USING (id > 0);
SELECT * FROM pg_get_table_ddl('rls_pol'::regclass, owner => false);
WARNING:  row-level security policies on table "rls_pol" are not reconstructed
DETAIL:  pg_get_table_ddl() does not yet emit CREATE POLICY statements; policies must be added manually.
                       pg_get_table_ddl                        
---------------------------------------------------------------
 CREATE TABLE pgtbl_ddl_test.rls_pol (id integer);
 ALTER TABLE pgtbl_ddl_test.rls_pol ENABLE ROW LEVEL SECURITY;
(2 rows)

