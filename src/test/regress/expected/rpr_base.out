-- Window with No Matching Rows
SELECT id, val,
       COUNT(*) OVER w as cnt
FROM rpr_stress
WHERE val > 1000  -- No rows match
WINDOW w AS (
    ORDER BY id
    ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING
    PATTERN (A+)
    DEFINE A AS val > 0
)
ORDER BY id;
 id | val | cnt 
