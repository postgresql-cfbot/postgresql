ALTER TABLE pko_ts ADD CONSTRAINT pko_ts_pk PRIMARY KEY (a)
    USING INDEX TABLESPACE regress_tblspace;
SELECT stmt FROM pg_get_table_ddl('pko_ts', owner => false) stmt;
